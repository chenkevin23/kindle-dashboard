# ── OpenClaw 集成 ──
# 日历缓存路径（icalBuddy 输出）
OPENCLAW_CALENDAR_CACHE=~/.openclaw/cache/calendar-today.txt

# gog CLI 账号（用于 Gmail）
GOG_ACCOUNT=chenk.ny@gmail.com

# ── Kindle 连接 ──
KINDLE_HOST=192.168.1.xxx
KINDLE_USER=root
KINDLE_SSH_KEY_PATH=~/.ssh/kindle_rsa
# 或者 base64 编码的私钥（用于 Railway）
# KINDLE_SSH_KEY_B64=...
KINDLE_REMOTE_PATH=/mnt/us/dashboard/dashboard.png

# ── S3/R2 上传（Railway 云端模式）──
# S3_BUCKET=kindle-dashboard
# S3_KEY=dashboard.png
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com

# ── RSS 新闻源 ──
RSS_FEEDS=[{"name":"TechCrunch","url":"https://techcrunch.com/feed/"},{"name":"Hacker News","url":"https://hnrss.org/frontpage?count=5"},{"name":"The Verge","url":"https://www.theverge.com/rss/index.xml"}]

# ── 显示设置 ──
TIMEZONE=America/Los_Angeles
OWNER_NAME=KC
MAX_EMAILS=5
MAX_EVENTS=8
MAX_NEWS=6
